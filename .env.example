# ============================================================
# AI Finance Assistant - Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# --- LLM Providers (choose at least one) ---
OPENAI_API_KEY=sk-proj-...
GOOGLE_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# --- Market Data ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key   # optional fallback
FINNHUB_API_KEY=your_finnhub_api_key            # get free key at finnhub.io

# --- Web Search ---
TAVILY_API_KEY=tvly-dev-...

# --- Observability ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com       # or self-hosted URL

# --- Guardrails (optional) ---
GUARDRAILS_API_KEY=eyJhbGci...

# --- LangSmith (optional) ---
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-finance-assistant
